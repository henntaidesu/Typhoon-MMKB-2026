# ===========================================================================
# Secrets & local config  —  KEEP OUT OF VERSION CONTROL
# ===========================================================================
# conf.ini holds real DB credentials (see backend/config.py). Commit a
# sanitized backend/conf.ini.example instead.
backend/conf.ini
conf.ini
*.local.ini
.env
.env.*
!.env.example

